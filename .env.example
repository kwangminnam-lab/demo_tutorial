# PostgreSQL (관계형: SSO 계정·access·소스 레지스트리). pgvector·tsvector 검색도 겸용(ADR-019).
# 로컬: docker compose 의 postgres 기본값. 무료 배포: Supabase(pgvector 포함).
#   Supabase 예: postgresql+psycopg://postgres:<PW>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg://postgres:platform@postgresql:5432/postgres

# docker-compose 의 postgres 초기화·인증에 사용 (앱은 DATABASE_URL만 읽는다).
POSTGRES_DB=docux
POSTGRES_USER=docux
POSTGRES_PASSWORD=CHANGE_ME

# 벡터 저장소 (의미 검색: 청크 임베딩 k-NN). 비우면 memory(InMemory) — 인프라 불요.
#   VECTOR_BACKEND: memory | opensearch | postgres  (postgres=pgvector, ADR-019)
VECTOR_BACKEND=memory
# 의미 검색용 k-NN 인덱스명(어휘 인덱스 OPENSEARCH_INDEX 와 분리). 첫 색인 시 자동 생성.
OPENSEARCH_CHUNK_INDEX=kms-chunks

# Neo4j (GraphDB: 문서·엔티티 관계). 무료 배포: Neo4j Aura(neo4j+s://<id>.databases.neo4j.io).
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# Backend 선택 (kms.factory) — 비우면 전부 경량 기본(fake/memory).
# 무료 스택(ADR-019): EMBEDDER=hf_api, SEARCH=postgres, VECTOR=postgres, GRAPH=neo4j(Aura),
#                     LLM=openai_compat(+Groq base_url).
#   EMBEDDER_BACKEND: fake | sentence_transformers | hf_api | openai_compat
#   LLM_BACKEND:      fake | openai_compat
#   GRAPH_BACKEND:    memory | neo4j
#   SEARCH_BACKEND:   memory | opensearch | postgres  (어휘 검색)
#   VECTOR_BACKEND:   memory | opensearch | postgres  (의미 검색 — 위 블록 참조)
# 사내 K8s 스택(ADR-019): EMBEDDER=openai_compat(liteLLM), LLM=openai_compat(liteLLM),
#                        VECTOR/SEARCH=postgres(사내 PG), GRAPH=neo4j(사내).
EMBEDDER_BACKEND=
LLM_BACKEND=
GRAPH_BACKEND=
SEARCH_BACKEND=memory

# OpenAI 호환 임베딩 프록시(EMBEDDER_BACKEND=openai_compat) — liteLLM `/v1/embeddings`.
# 사내 K8s면 service DNS로: http://litellm.<ns>.svc.cluster.local:4000/v1
# 모델은 EMBEDDING_MODEL_NAME 재사용. 사내 프록시는 보통 키 불요(있으면 EMBED_API_KEY).
EMBED_BASE_URL=http://localhost:4000/v1
EMBED_API_KEY=

# CORS — 프론트(GitHub Pages 등)가 다른 오리진의 백엔드를 호출할 때 필요.
# 콤마 구분 오리진 목록. 비우면 동일 오리진 전용(로컬 dev는 vite proxy로 충분).
#   예: https://kwang-min-n.github.io
CORS_ALLOW_ORIGINS=

# 통합 검색 어휘 인덱스 (SEARCH_BACKEND=opensearch 일 때). 인덱스는 첫 색인 시
# Nori 매핑으로 자동 생성된다(create-if-absent). 로컬은 docker compose 의 opensearch.
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=kms-files

# 실 임베딩 모델 (EMBEDDER_BACKEND=sentence_transformers 일 때). 비우면 한국어
# 포함 multilingual 기본(paraphrase-multilingual-MiniLM-L12-v2).
EMBEDDING_MODEL_NAME=

# 로컬 Gemma 추론 모델 경로 (HF safetensors)
LLM_MODEL_PATH=/Users/kwangmin/local_model/gemma_model_e4b

# 기본(gemma 슬롯) LLM = OpenAI 호환 /v1 서버 (LLM_BACKEND=openai_compat).
# 무료 배포: Groq(OpenAI 호환, 무료 티어) — ADR-019.
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=<groq_api_key>
#   LLM_MODEL_NAME=gemma2-9b-it
# 로컬 서버(사내, 키 불요)면 아래 기본값. (ADR-007 로컬 우선은 무료 배포에서 완화)
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL_NAME=gemma
LLM_API_KEY=

# Gemini 무료 티어 서버측 키 — provider=gemini를 사용자 키 없이 동작시킨다(ADR-019).
GEMINI_API_KEY=

# 임베딩·리랭킹 HuggingFace Inference API 키 (EMBEDDER_BACKEND=hf_api — ADR-019).
HF_API_KEY=

# SSO (OAuth2/OIDC)
SSO_ISSUER=
SSO_CLIENT_ID=

# 세션 토큰(JWT) 서명 비밀키 (ADR-017 비밀번호 인증). 비번 로그인에 필수.
# 최소 32바이트 권장(HS256). 운영은 시크릿 매니저로 주입(코드/git 미포함).
JWT_SECRET=
JWT_EXPIRE_MINUTES=720
