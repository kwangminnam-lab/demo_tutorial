# 백엔드 이미지 빌드 컨텍스트에서 제외할 것 — 이미지 크기·빌드 속도·시크릿 보호.

# 대용량 코퍼스(519MB) — 운영은 PVC 볼륨으로 /app/data에 마운트(이미지에 굽지 않음).
data/

# 시크릿·로컬 설정 — 절대 이미지에 넣지 않는다(K8s Secret/ConfigMap로 주입).
.env
.env.*
*.pem
*.key
credentials*

# 파이썬 가상환경·캐시·빌드 산출물.
.venv/
venv/
**/__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# 프론트엔드 — 별도 이미지(frontend/Dockerfile)로 빌드. 백엔드 컨텍스트엔 불요.
frontend/

# VCS·IDE·문서·다이어그램·로그.
.git/
.github/
.gitignore
.idea/
.vscode/
*.log
*.md
docs/
description/
phases/
*.excalidraw
.DS_Store

# 하네스 메타 도구(앱 코드 아님).
.claude/
